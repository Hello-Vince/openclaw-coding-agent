{
  "version": 1,
  "defaults": {
    "security": "allowlist",
    "ask": "off",
    "askFallback": "allowlist",
    "autoAllowSkills": true
  },
  "agents": {
    "coder": {
      "security": "allowlist",
      "ask": "off",
      "askFallback": "allowlist",
      "autoAllowSkills": true,
      "allowlist": [
        { "pattern": "/usr/local/bin/npm" },
        { "pattern": "/usr/local/bin/npx" },
        { "pattern": "/usr/local/bin/node" },
        { "pattern": "/usr/local/bin/pnpm" },
        { "pattern": "/usr/local/bin/pnpx" },
        { "pattern": "/usr/local/bin/yarn" },
        { "pattern": "/usr/local/bin/tsx" },
        { "pattern": "/usr/local/bin/ts-node" },
        { "pattern": "/usr/local/bin/tsc" },
        { "pattern": "/usr/local/bin/eslint" },
        { "pattern": "/usr/local/bin/prettier" },
        { "pattern": "/usr/local/bin/kilo" },
        { "pattern": "/usr/local/bin/openclaw" },
        { "pattern": "/home/node/.local/bin/cursor-agent" },
        { "pattern": "/home/node/.local/bin/agent" },
        { "pattern": "/root/.local/bin/poetry" },
        { "pattern": "/usr/bin/python3" },
        { "pattern": "/usr/bin/git" },
        { "pattern": "/usr/bin/cat" },
        { "pattern": "/usr/bin/ls" },
        { "pattern": "/usr/bin/find" },
        { "pattern": "/usr/bin/grep" },
        { "pattern": "/usr/bin/echo" },
        { "pattern": "/usr/bin/mkdir" },
        { "pattern": "/usr/bin/rm" },
        { "pattern": "/usr/bin/cp" },
        { "pattern": "/usr/bin/mv" },
        { "pattern": "/usr/bin/bash" },
        { "pattern": "/usr/bin/sh" },
        { "pattern": "/usr/bin/env" },
        { "pattern": "/usr/bin/sed" },
        { "pattern": "/usr/bin/awk" },
        { "pattern": "/usr/bin/sort" },
        { "pattern": "/usr/bin/head" },
        { "pattern": "/usr/bin/tail" },
        { "pattern": "/usr/bin/wc" },
        { "pattern": "/usr/bin/touch" },
        { "pattern": "/usr/bin/chmod" },
        { "pattern": "/usr/bin/xargs" },
        { "pattern": "/usr/bin/tee" },
        { "pattern": "/usr/bin/dirname" },
        { "pattern": "/usr/bin/basename" },
        { "pattern": "/usr/bin/realpath" },
        { "pattern": "/usr/bin/test" },
        { "pattern": "/usr/bin/tr" },
        { "pattern": "/usr/bin/cut" },
        { "pattern": "/usr/bin/uniq" },
        { "pattern": "/usr/bin/diff" },
        { "pattern": "/workspace/**" }
      ]
    }
  }
}
