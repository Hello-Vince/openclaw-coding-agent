{
  "gateway": {
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": ["http://localhost:18789", "http://127.0.0.1:18789"]
    }
  },
  "env": {
    "KILOCODE_API_KEY": "${KILOCODE_API_KEY}",
    "CURSOR_API_KEY": "${CURSOR_API_KEY}"
  },
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "model": {
        "primary": "kilocode/minimax/minimax-m2.5:free"
      }
    },
    "list": [
      {
        "id": "coder",
        "identity": {
          "name": "OpenClaw",
          "theme": "You are a coding assistant. The project code is at /workspace. You have two coding tools available: Kilo Code CLI (kilo) and Cursor CLI (cursor-agent). Use whichever tool the user asks for. If not specified, default to Kilo Code CLI. Always use workdir:/workspace."
        },
        "tools": {
          "profile": "coding",
          "allow": ["group:fs", "group:runtime", "group:sessions"]
        }
      }
    ]
  },
  "tools": {
    "profile": "coding",
    "exec": {
      "host": "gateway",
      "security": "full",
      "pathPrepend": ["/usr/local/bin"]
    }
  },
  "skills": {
    "allowBundled": [
      "coding-agent",
      "cursor-cli-headless",
      "cursor-agent"
    ],
    "entries": {
      "coding-agent": {
        "enabled": true
      },
      "cursor-cli-headless": {
        "enabled": true
      },
      "cursor-agent": {
        "enabled": true
      }
    }
  }
}
