# Kilo Code API key -- get one at https://app.kilo.ai (sign in, copy key from profile).
# Used by OpenClaw as the AI model provider and by Kilo Code CLI for coding.
KILOCODE_API_KEY=sk-replace-me

# Cursor API key -- provided by your company's Cursor account.
# Only needed if you switch to the "cursor" agent (see README).
CURSOR_API_KEY=replace-me

# Random token used to authenticate with the Control UI.
# Generate one with:  openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=replace-me-with-a-random-token

# Absolute path to the project directory you want OpenClaw to work on.
# This is bind-mounted into the container at /workspace.
PROJECT_PATH=/absolute/path/to/your/project
